\$env.SYS_OS_PLAT = r#'darwin'#

\$env.REQ_PATH = r#'/sh/nu/virt/add'#

\$env.REQ_SRCH = r#'?sysOsPlat=darwin'#

opPrintInfo r#'id: wut virt add | add on local
aliases: a, ad, in, install
arguments:
  - <parts> | path part(s) to match'#
\`
`;

