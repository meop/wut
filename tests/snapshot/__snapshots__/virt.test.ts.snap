\$env.REQ_ORIG = r#'http://x'#

\$env.SYS_OS_PLAT = r#'winnt'#

\$env.REQ_PATH = r#'/sh/nu/virt/sync'#

\$env.REQ_SRCH = r#'?sysOsPlat=winnt'#

\$env.VIRT_OP = r#'sync'#

def virtDockerOp [cmd] {
  for instance in \$env.VIRT_INSTANCES {
    if (do --ignore-errors { ^\$cmd container ls } | find --ignore-case \$instance | is-empty) {
      continue
    }
    let url = \$"(\$env.REQ_URL_CFG)/virt/(\$env.SYS_HOST)/(\$cmd)/(\$instance).yaml"
    opPrintMaybeRunCmd '\$"(' http get --raw --redirect-mode follow \$"r#'(\$url)'#" ')"' '|' \$cmd compose --file - up --detach --pull always
  }
}


def virtDocker [] {
  try {
    mut yn = ''
    let cmd = 'docker'
    if ('VIRT_MANAGER' not-in \$env or \$env.VIRT_MANAGER == \$cmd) and (which \$cmd | is-not-empty) {
      if 'YES' in \$env {
        \$yn = 'y'
      } else {
        \$yn = input \$"? use (\$cmd) \\\\(system\\\\) [y, [n]]: "
      }
      if \$yn != 'n' {
        virtDockerOp \$cmd
      }
    }
  } catch { |e|
    if not ((\$e.msg | str downcase) == 'i/o error') {
      error make \$e
    }
  }
}

\`
`;

