      }
      if \$yn != 'n' {
        virtDockerOp \$cmd
      }
    }
  } catch { |e|
    if not ((\$e.msg | str downcase) == 'i/o error') {
      error make \$e
    }
  }
}


def virtQemuOp [cmd, cmdSysArch] {}

def virtQemu [] {
  try {
    let cmd = 'qemu'
