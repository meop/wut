\$env.REQ_ORIG = r#'http://x'#

\$env.SYS_OS_PLAT = r#'darwin'#

\$env.REQ_PATH = r#'/sh/nu/file/find'#

\$env.REQ_SRCH = r#'?sysOsPlat=darwin'#

def fileOp [] {
  for entry in \$env.FILE_FIND_KEYS {
    let parts = \$entry | split row '|'
    let keys = \$parts | get 0
    let ins = if (\$parts | length) > 1 { \$parts | get 1 } else { '' }

    mut bin = ''
    for alias in (\$keys | split row ',') {
      if (which \$alias | is-not-empty) {
        \$bin = \$alias
        break
      }
    }
    if (\$bin | is-empty) {
      continue
    }

    opPrint \$bin
    if (\$ins | is-not-empty) {
      opPrint \$"  (\$ins)"
    }
  }
}


def replaceEnv [line] {
  mut l = \$line
  if (\$l | str contains '{') {
    let itemsEnv = \$env | items { |key, value| [\$key, \$value] }
    for e in (\$itemsEnv | where { |e| ((\$e.0 | describe) == 'string') and ((\$e.1 | describe) == 'string') }) {
      \$l = \$l | str replace --all \$"{(\$e.0)}" (\$e.1)
    }
  }
  return \$l
}
def file [] {
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input r#'? use file (user) [y, [n]]: '#
  }
  if \$yn != 'n' {
    fileOp
  }
}


\$env.FILE_FIND_KEYS = [ r#'docker|config.json'#, r#'fzf|theme.zsh, theme.ps1'#, r#'ghostty|config, themes'#, r#'nu|nu, env.nu, config.nu'#, r#'nvim|init.lua, lua'#, r#'pwsh|pwsh, env.ps1, profile.ps1'#, r#'ssh|hushlogin'#, r#'starship|starship.toml'#, r#'zellij|config.kdl, themes'#, r#'zsh|zsh, zshenv, zshrc'# ]

