\$env.REQ_ORIG = r#'http://x'#

\$env.SYS_OS_PLAT = r#'winnt'#

\$env.REQ_PATH = r#'/sh/nu/file/diff'#

\$env.REQ_SRCH = r#'?sysOsPlat=winnt'#

def fileOp [] {
  for pair in \$env.FILE_DIFF_PATH_PAIRS {
    let pairParts = \$pair | split row '|'

    mut bin = ''
    for alias in (\$pairParts.0 | split row ',') {
      if (which \$alias | is-not-empty) {
        \$bin = \$alias
        break
      }
    }
    if (\$bin | is-empty) {
      continue
    }

    let src = \$pairParts.1 | str trim --left --char '/'
    let dst = replaceEnv \$pairParts.2 | path expand

    let url = \$\\"(\$env.REQ_URL_CFG)/file/(\$src)\\"

    let fileNewTemp = opPrintRunCmd mktemp --suffix '.file.diff.tmp' --tmpdir
    opPrintMaybeRunCmd '\$\\"(' http get --raw --redirect-mode follow \$\\"r#'(\$url)'#\\" ')\\"' '|' save --force \$\\"r#'(\$fileNewTemp)'#\\"

    let diffCmd = if (which diff | is-not-empty) { 'diff' } else { 'fc' }

    if (\$dst | path exists) {
      opPrintMaybeRunCmd \$diffCmd \$\\"r#'(\$dst)'#\\" \$\\"r#'(\$fileNewTemp)'#\\" '|' complete '|' get stdout '|' str trim --right
    } else {
      opPrintWarn \$\\"\`(\$dst)\` does not exist\\"
    }

    opPrintRunCmd rm --force \$\\"r#'(\$fileNewTemp)'#\\"
  }
}


def replaceEnv [line] {
  mut l = \$line
  if (\$l | str contains '{') {
    let itemsEnv = \$env | items { |key, value| [\$key, \$value] }
    for e in (\$itemsEnv | where { |e| ((\$e.0 | describe) == 'string') and ((\$e.1 | describe) == 'string') }) {
      \$l = \$l | str replace --all \$\\"{(\$e.0)}\\" (\$e.1)
    }
  }
  return \$l
}
def file [] {
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input r#'? use file (user) [y, [n]]: '#
  }
  if \$yn != 'n' {
    fileOp
  }
}


\$env.FILE_DIFF_PATH_PAIRS = [ r#'docker|docker/config.json|{HOME}/.docker/config.json'#, r#'fzf|fzf/theme.ps1|{HOME}/.fzf/theme.ps1'#, r#'nu|nu/nu/00-vim.nu|{HOME}/AppData/Roaming/nushell/autoload/00-vim.nu'#, r#'nu|nu/nu/01-nvim.nu|{HOME}/AppData/Roaming/nushell/autoload/01-nvim.nu'#, r#'nu|nu/nu/70-wut.nu|{HOME}/AppData/Roaming/nushell/autoload/70-wut.nu'#, r#'nu|nu/env.nu|{HOME}/AppData/Roaming/nushell/env.nu'#, r#'nu|nu/config.nu|{HOME}/AppData/Roaming/nushell/config.nu'#, r#'nvim|nvim/init.lua|{HOME}/AppData/Local/nvim/init.lua'#, r#'nvim|nvim/lua/plugins/spec.lua|{HOME}/AppData/Local/nvim/lua/plugins/spec.lua'#, r#'pwsh|pwsh/pwsh/05-bun.ps1|{HOME}/.pwsh/05-bun.ps1'#, r#'pwsh|pwsh/pwsh/05-deno.ps1|{HOME}/.pwsh/05-deno.ps1'#, r#'pwsh|pwsh/pwsh/05-zed.ps1|{HOME}/.pwsh/05-zed.ps1'#, r#'pwsh|pwsh/pwsh/10-vim.ps1|{HOME}/.pwsh/10-vim.ps1'#, r#'pwsh|pwsh/pwsh/11-nvim.ps1|{HOME}/.pwsh/11-nvim.ps1'#, r#'pwsh|pwsh/pwsh/20-fzf.ps1|{HOME}/.pwsh/20-fzf.ps1'#, r#'pwsh|pwsh/pwsh/70-wut.ps1|{HOME}/.pwsh/70-wut.ps1'#, r#'pwsh|pwsh/pwsh/99-bin.ps1|{HOME}/.pwsh/99-bin.ps1'#, r#'pwsh|pwsh/env.ps1|{HOME}/Documents/PowerShell/env.ps1'#, r#'pwsh|pwsh/profile.ps1|{HOME}/Documents/PowerShell/profile.ps1'#, r#'ssh|ssh/hushlogin|{HOME}/.hushlogin'#, r#'starship|starship/starship.toml|{HOME}/.config/starship.toml'#, r#'winget|winget/settings.json|{HOME}/AppData/Local/Packages/Microsoft.DesktopAppInstaller_8wekyb3d8bbwe/LocalState/settings.json'#, r#'wsl|wsl/wslconfig|{HOME}/.wslconfig'# ]

