  opPrintCmd ...\$args
  opRunCmd ...\$args
}

def opPrintMaybeRunCmd --wrapped [...args] {
  opPrintCmd ...\$args
  if 'NOOP' not-in \$env {
    opRunCmd ...\$args
  }
}


\$env.SH_VER_MAJOR = 0

\$env.SH_VER_MINOR = 111

do {
  let major = \$env.SH_VER_MAJOR | into int
  let minor = \$env.SH_VER_MINOR | into int

  if ((version | get major) < \$major) or ((version | get minor) < \$minor) {
    opPrintErr \$"nu must be >= '(\$major).(\$minor)' .. found '(version | get version)' .. aborting"
    exit 1
  }
}


\$env.REQ_ORIG = r#'http://x'#

\$env.SYS_OS_ID = r#'suse'#

\$env.SYS_OS_PLAT = r#'linux'#

\$env.REQ_PATH = r#'/sh/nu/pack/add/firefox'#

\$env.REQ_SRCH = r#'?sysOsPlat=linux&sysOsId=suse'#

\$env.PACK_ADD_NAMES = r#'firefox'#

\$env.PACK_OP = r#'add'#

def packZypperOp [cmd] {
  if 'PACK_ADD_GROUP_NAMES' in \$env {
    for name in \$env.PACK_ADD_GROUP_NAMES {
      opPrintMaybeRunCmd ...(\$name | split row ' ')
    }
  }
  opPrintMaybeRunCmd \$cmd install \$env.PACK_ADD_NAMES
}


def packZypper [] {
  try {
    let cmd = 'zypper'
    if ('PACK_MANAGER' not-in \$env or \$env.PACK_MANAGER == \$cmd) and (which \$cmd | is-not-empty) {
      mut yn = ''
      if 'YES' in \$env {
        \$yn = 'y'
      } else {
        \$yn = input \$"? use (\$cmd) \\\\(system\\\\) [y, [n]]: "
      }
      if \$yn != 'n' {
        let cmd = if (which sudo | is-not-empty) { \$"sudo (\$cmd)" } else { \$cmd }
        if 'PACK_OP' in \$env and (\$env.PACK_OP == 'add' or \$env.PACK_OP == 'find' or \$env.PACK_OP == 'out' or \$env.PACK_OP == 'sync') {
          opPrintMaybeRunCmd \$cmd refresh '|' complete '|' ignore
        }
        packZypperOp \$cmd
      }
    }
  } catch { |e|
    if not ((\$e.msg | str downcase) == 'i/o error') {
      error make \$e
    }
  }
}


\$env.PACK_ADD_NAMES = r#'firefox'#

packZypper
\`
`;

