        }
        packPacmanOp \$cmd
      }
    }
  } catch { |e|
    if not ((\$e.msg | str downcase) == 'i/o error') {
      error make \$e
    }
  }
}
def packPacman [] {
  try {
    let cmd = 'pacman'
    if ('PACK_MANAGER' not-in \$env) and (which yay | is-not-empty) {
      # yay is a superset of pacman
    } else if ('PACK_MANAGER' not-in \$env or \$env.PACK_MANAGER == \$cmd) and (which \$cmd | is-not-empty) {
      mut yn = ''
