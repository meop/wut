    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi magenta)(\$args | first)(ansi reset)" | print --no-newline
  if (\$args | length) > 1 {
    \$" (ansi cyan)(\$args | skip 1 | str join ' ')(ansi reset)" | print
  }
}

def opRunCmd --wrapped [...args] {
  nu --no-config-file -c \$"(\$args | str join ' ')"
}

def opPrintRunCmd --wrapped [...args] {
  opPrintCmd ...\$args
  opRunCmd ...\$args
}

def opPrintMaybeRunCmd --wrapped [...args] {
  opPrintCmd ...\$args
  if 'NOOP' not-in \$env {
    opRunCmd ...\$args
  }
}


\$env.SH_VER_MAJOR = 0

\$env.SH_VER_MINOR = 111

do {
  let major = \$env.SH_VER_MAJOR | into int
  let minor = \$env.SH_VER_MINOR | into int

  if ((version | get major) < \$major) or ((version | get minor) < \$minor) {
    opPrintErr \$"nu must be >= '(\$major).(\$minor)' .. found '(version | get version)' .. aborting"
    exit 1
  }
}


\$env.REQ_ORIG = r#'http://x'#

\$env.SYS_OS_PLAT = r#'winnt'#

\$env.REQ_PATH = r#'/sh/nu/pack/sync'#

\$env.REQ_SRCH = r#'?sysOsPlat=winnt'#

\$env.PACK_OP = r#'sync'#

def packChocoOp [cmd] {
  if 'PACK_SYNC_NAMES' in \$env {
    opPrintMaybeRunCmd \$cmd upgrade \$env.PACK_SYNC_NAMES
  } else {
    opPrintMaybeRunCmd \$cmd upgrade all
  }
}


def packChoco [] {
  try {
    let cmd = 'choco'
    if ('PACK_MANAGER' not-in \$env or \$env.PACK_MANAGER == \$cmd) and (which \$cmd | is-not-empty) {
      mut yn = ''
      if 'YES' in \$env {
        \$yn = 'y'
      } else {
        \$yn = input \$"? use (\$cmd) \\\\(system\\\\) [y, [n]]: "
      }
      if \$yn != 'n' {
        let cmd = if (which sudo | is-not-empty) { \$"sudo (\$cmd)" } else { \$cmd }
        packChocoOp \$cmd
      }
    }
  } catch { |e|
    if not ((\$e.msg | str downcase) == 'i/o error') {
      error make \$e
    }
  }
}


def packScoopOp [cmd] {
  if 'PACK_SYNC_NAMES' in \$env {
    opPrintMaybeRunCmd \$cmd update \$env.PACK_SYNC_NAMES
  } else {
    opPrintMaybeRunCmd \$cmd update --all
  }
}


def packScoop [] {
  try {
    let cmd = 'scoop'
    if ('PACK_MANAGER' not-in \$env or \$env.PACK_MANAGER == \$cmd) and (which \$cmd | is-not-empty) {
      mut yn = ''
      if 'YES' in \$env {
        \$yn = 'y'
      } else {
        \$yn = input \$"? use (\$cmd) \\\\(user\\\\) [y, [n]]: "
      }
      if \$yn != 'n' {
        if 'PACK_OP' in \$env and (\$env.PACK_OP == 'add' or \$env.PACK_OP == 'find' or \$env.PACK_OP == 'out' or \$env.PACK_OP == 'sync') {
          opPrintMaybeRunCmd \$cmd update '|' complete '|' ignore
        }
        packScoopOp \$cmd
      }
    }
  } catch { |e|
    if not ((\$e.msg | str downcase) == 'i/o error') {
      error make \$e
    }
  }
}


def packWingetOp [cmd] {
  if 'PACK_SYNC_NAMES' in \$env {
    opPrintMaybeRunCmd \$cmd upgrade \$env.PACK_SYNC_NAMES
  } else {
    opPrintMaybeRunCmd \$cmd upgrade --all
  }
}


def packWinget [] {
  try {
    let cmd = 'winget'
    if ('PACK_MANAGER' not-in \$env or \$env.PACK_MANAGER == \$cmd) and (which \$cmd | is-not-empty) {
      if \$env.PACK_OP == 'tidy' {
        return
      }
      mut yn = ''
      if 'YES' in \$env {
        \$yn = 'y'
      } else {
        \$yn = input \$"? use (\$cmd) \\\\(system/user\\\\) [y, [n]]: "
      }
      if \$yn != 'n' {
        packWingetOp \$cmd
      }
    }
  } catch { |e|
    if not ((\$e.msg | str downcase) == 'i/o error') {
      error make \$e
    }
  }
}


packChoco
packScoop
packWinget
\`
`;

