\$env.REQ_ORIG = r#'http://x'#

\$env.SYS_OS_ID = r#'arch'#

\$env.SYS_OS_PLAT = r#'linux'#

\$env.REQ_PATH = r#'/cli/nu/pack/find/firefox'#

\$env.REQ_SRCH = r#'?sysOsPlat=linux&sysOsId=arch'#

\$env.PACK_FIND_NAMES = r#'firefox'#

\$env.PACK_OP = r#'find'#





def packPacmanOp [cmd] {
  opPrintMaybeRunCmd \$cmd --sync --search \$env.PACK_FIND_NAMES
}


def packYay [] {
  try {
    let cmd = 'yay'
    if ('PACK_MANAGER' not-in \$env or \$env.PACK_MANAGER == \$cmd) and (which \$cmd | is-not-empty) {
