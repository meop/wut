\$env.REQ_ORIG = r#'http://x'#

\$env.SYS_OS_PLAT = r#'linux'#

\$env.REQ_PATH = r#'/sh/nu/virt/find'#

\$env.REQ_SRCH = r#'?sysOsPlat=linux'#

\$env.VIRT_OP = r#'find'#

do --env {
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input r#'use virt [y,[n]]: '#
  }
  if \$yn != 'n' {
opPrint r#'lxc'#
opPrint r#'podman'#
opPrint r#'  undefined'#
opPrint r#'qemu'#
  }
}
\`
`;

