  }
  if \$yn == 'n' {
    return
  }
  let cmd = if (which sudo | is-not-empty) { \$"sudo (\$cmd)" } else { \$cmd }
  packChocoOp \$cmd
}


def --env packScoopOp [cmd] {
  opPrintMaybeRunCmd \$cmd cleanup --all --cache
}


def --env packScoop [] {
