  let minor = \$env.SH_VERS_MINOR | into int

  if ((version | get major) < \$major) or ((version | get minor) < \$minor) {
    opPrintErr \$"nu must be >= '(\$major).(\$minor)' .. found '(version | get version)' .. aborting"
    exit 1
  }
}


\$env.REQ_ORIG = r#'http://x'#

\$env.SYS_OS = r#'alpine'#

\$env.SYS_OS_PLAT = r#'linux'#

\$env.REQ_PATH = r#'/sh/nu/pack/find/firefox'#

\$env.REQ_SRCH = r#'?sysOsPlat=linux&sysOs=alpine'#

\$env.PACK_FIND_NAMES = r#'firefox'#

\$env.PACK_OP = r#'find'#

def --env packCargoOp [cmd] {
  for term in (\$env.PACK_FIND_NAMES | split words) {
    opPrintMaybeRunCmd \$cmd search \$term
  }
}


def --env packCargo [] {
  let cmd = 'cargo'
  if ('PACK_MANAGER' in \$env and \$env.PACK_MANAGER != \$cmd) or (which \$cmd | is-empty) {
    return
  }
  if ('PACK_OP' in \$env) and (\$env.PACK_OP in ['add', 'rem']) and (\$env.PACKED? | default false) {
    return
  }
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input \$"? use (\$cmd) \\\\(user\\\\) [y, [n]]: "
  }
  if \$yn == 'n' {
    return
  }
  packCargoOp \$cmd
}


def --env packApkOp [cmd] {
  for term in (\$env.PACK_FIND_NAMES | split words) {
    opPrintMaybeRunCmd \$cmd search \$term
  }
}


def --env packApk [] {
  let cmd = 'apk'
  if ('PACK_MANAGER' in \$env and \$env.PACK_MANAGER != \$cmd) or (which \$cmd | is-empty) {
    return
  }
  if ('PACK_OP' in \$env) and (\$env.PACK_OP in ['add', 'rem']) and (\$env.PACKED? | default false) {
    return
  }
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input \$"? use (\$cmd) \\\\(system\\\\) [y, [n]]: "
  }
  if \$yn == 'n' {
    return
  }
  let cmd = if (which sudo | is-not-empty) { \$"sudo (\$cmd)" } else { \$cmd }
  if 'PACK_OP' in \$env and (\$env.PACK_OP == 'add' or \$env.PACK_OP == 'find' or \$env.PACK_OP == 'out' or \$env.PACK_OP == 'sync') {
    opPrintMaybeRunCmd \$cmd update '|' complete '|' ignore
  }
  packApkOp \$cmd
}


do {
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input r#'? use pack [y, [n]]: '#
  }
  if \$yn != 'n' {
  }
}

\$env.PACK_FIND_NAMES = r#'firefox'#

packCargo
packApk
\`
`;

