def opPrintSucc --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi green)(\$args | str join ' ')(ansi reset)" | print
}

def opPrintWarn --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi yellow)(\$args | str join ' ')(ansi reset)" | print
}

def opPrintInfo --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi blue)(\$args | str join ' ')(ansi reset)" | print
}

def opPrintCmd --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi magenta)(\$args | first)(ansi reset)" | print --no-newline
  if (\$args | length) > 1 {
    \$" (ansi cyan)(\$args | skip 1 | str join ' ')(ansi reset)" | print
  }
}

def opRunCmd --wrapped [...args] {
  nu --no-config-file -c \$"(\$args | str join ' ')"
}

def opPrintRunCmd --wrapped [...args] {
  opPrintCmd ...\$args
  opRunCmd ...\$args
}

def opPrintMaybeRunCmd --wrapped [...args] {
  opPrintCmd ...\$args
  if 'NOOP' not-in \$env {
    opRunCmd ...\$args
  }
}


\$env.SH_VERS_MAJOR = 0

\$env.SH_VERS_MINOR = 111

do {
  let major = \$env.SH_VERS_MAJOR | into int
  let minor = \$env.SH_VERS_MINOR | into int

  if ((version | get major) < \$major) or ((version | get minor) < \$minor) {
    opPrintErr \$"nu must be >= '(\$major).(\$minor)' .. found '(version | get version)' .. aborting"
    exit 1
  }
}


\$env.SYS_CPU_ARCH = match (uname | get machine | str downcase) {
  'arm64' => 'aarch64',
  'amd64' => 'x86_64',
  \$x => \$x,
}
\$env.REQ_URL_SH = \$"(\$env.REQ_URL_SH)?sysCpuArch=(\$env.SYS_CPU_ARCH)"

\$env.SYS_CPU_VEND = match (sys cpu | first | get vendor_id | split words | first | str downcase) {
  'genuineintel' => 'intel',
  'authenticamd' => 'amd',
  'qemu' => 'apple',
  \$x => \$x,
}
\$env.REQ_URL_SH = \$"(\$env.REQ_URL_SH)&sysCpuVend=(\$env.SYS_CPU_VEND)"

\$env.SYS_HOST = sys host | get hostname | str downcase
\$env.REQ_URL_SH = \$"(\$env.REQ_URL_SH)&sysHost=(\$env.SYS_HOST)"

\$env.SYS_OS_PLAT = match (uname | get kernel-name | str downcase) {
  'darwin' => 'darwin',
  'linux' => 'linux',
  'windows_nt' => 'winnt',
  \$x => \$x,
}
\$env.REQ_URL_SH = \$"(\$env.REQ_URL_SH)&sysOsPlat=(\$env.SYS_OS_PLAT)"

if \$env.SYS_OS_PLAT == 'linux' {
  if 'SYS_OS_DE' not-in \$env {
    if 'XDG_SESSION_DESKTOP' in \$env {
      \$env.SYS_OS_DE = \$env.XDG_SESSION_DESKTOP | str downcase
    }
    if 'SYS_OS_DE' in \$env {
      \$env.SYS_OS_DE = match \$env.SYS_OS_DE {
        'kde' => 'plasma',
        'rpd' | 'rpd-labwc' => 'lxde',
        \$x => \$x,
      }
      \$env.REQ_URL_SH = \$"(\$env.REQ_URL_SH)&sysOsDe=(\$env.SYS_OS_DE)"
    }
  }

  if ('/etc/os-release' | path exists) {
    open /etc/os-release
      | lines
      | parse "{key}={value}"
      | update value { |v| str trim --char '"' }
      | transpose --as-record --header-row
      | load-env

    if 'SYS_OS' not-in \$env {
      if 'ID' in \$env {
        \$env.SYS_OS = \$env.ID | str downcase
      }
      if 'SYS_OS' in \$env {
        \$env.REQ_URL_SH = \$"(\$env.REQ_URL_SH)&sysOs=(\$env.SYS_OS)"
      }
    }

    if 'SYS_OS_LIKE' not-in \$env {
      if 'SYS_OS' in \$env {
        let _parts = if 'ID_LIKE' in \$env { \$env.ID_LIKE | str downcase | split words } else { [] }
        \$env.SYS_OS_LIKE = ([\$env.SYS_OS] ++ \$_parts) | str join '-'
        \$env.REQ_URL_SH = \$"(\$env.REQ_URL_SH)&sysOsLike=(\$env.SYS_OS_LIKE)"
      }
    }

    if 'SYS_OS_VERS' not-in \$env {
      if 'VERSION_ID' in \$env {
        \$env.SYS_OS_VERS = \$env.VERSION_ID | str downcase
      }
      if 'SYS_OS_VERS' in \$env {
        \$env.REQ_URL_SH = \$"(\$env.REQ_URL_SH)&sysOsVers=(\$env.SYS_OS_VERS)"
      }
    }

    if 'SYS_OS_VERS_CODE' not-in \$env {
      if 'VERSION_CODENAME' in \$env {
        \$env.SYS_OS_VERS_CODE = \$env.VERSION_CODENAME | str downcase
      }
      if 'SYS_OS_VERS_CODE' in \$env {
        \$env.REQ_URL_SH = \$"(\$env.REQ_URL_SH)&sysOsVersCode=(\$env.SYS_OS_VERS_CODE)"
      }
    }
  }
}

\$env.SYS_USER = whoami | str downcase
\$env.REQ_URL_SH = \$"(\$env.REQ_URL_SH)&sysUser=(\$env.SYS_USER)"


nu --no-config-file -c \$"( http get --raw --redirect-mode follow \$"(\$env.REQ_URL_SH)" )"

\`
`;
