    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi green)(\$args | str join ' ')(ansi reset)" | print
}

def opPrintWarn --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi yellow)(\$args | str join ' ')(ansi reset)" | print
}

def opPrintInfo --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi blue)(\$args | str join ' ')(ansi reset)" | print
}

def opPrintCmd --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi magenta)(\$args | first)(ansi reset)" | print --no-newline
  if (\$args | length) > 1 {
    \$" (ansi cyan)(\$args | skip 1 | str join ' ')(ansi reset)" | print
  }
}

def opRunCmd --wrapped [...args] {
  nu --no-config-file -c \$"(\$args | str join ' ')"
}

def opPrintRunCmd --wrapped [...args] {
  opPrintCmd ...\$args
  opRunCmd ...\$args
}

def opPrintMaybeRunCmd --wrapped [...args] {
  opPrintCmd ...\$args
  if 'NOOP' not-in \$env {
    opRunCmd ...\$args
  }
}


\$env.SH_VERS_MAJOR = 0

\$env.SH_VERS_MINOR = 111

do {
  let major = \$env.SH_VERS_MAJOR | into int
  let minor = \$env.SH_VERS_MINOR | into int

  if ((version | get major) < \$major) or ((version | get minor) < \$minor) {
    opPrintErr \$"nu must be >= '(\$major).(\$minor)' .. found '(version | get version)' .. aborting"
    exit 1
  }
}


\$env.REQ_ORIG = r#'http://x'#

\$env.SYS_OS_PLAT = r#'winnt'#

\$env.REQ_PATH = r#'/sh/nu/pack/list'#

\$env.REQ_SRCH = r#'?sysOsPlat=winnt'#

\$env.PACK_OP = r#'list'#

def --env packCargoOp [cmd] {
  let filterArgs = \$env.PACK_LIST_NAMES | split words | each { |t| ['|', 'find', '--ignore-case', \$t] } | flatten
  if (\$filterArgs | is-not-empty) {
    opPrintMaybeRunCmd \$cmd install --list ...\$filterArgs
  } else {
    opPrintMaybeRunCmd \$cmd install --list
  }
}


def --env packCargo [] {
  let cmd = 'cargo'
  if ('PACK_MANAGER' in \$env and \$env.PACK_MANAGER != \$cmd) or (which \$cmd | is-empty) {
    return
  }
  if ('PACK_OP' in \$env) and (\$env.PACK_OP in ['add', 'rem']) and (\$env.PACKED? | default false) {
    return
  }
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input \$"? use (\$cmd) \\\\(user\\\\) [y, [n]]: "
  }
  if \$yn == 'n' {
    return
  }
  packCargoOp \$cmd
}


def --env packChocoOp [cmd] {
  let filterArgs = \$env.PACK_LIST_NAMES | split words | each { |t| ['|', 'find', '--ignore-case', \$t] } | flatten
  if (\$filterArgs | is-not-empty) {
    opPrintMaybeRunCmd \$cmd list ...\$filterArgs
  } else {
    opPrintMaybeRunCmd \$cmd list
  }
}


def --env packChoco [] {
  let cmd = 'choco'
  if ('PACK_MANAGER' in \$env and \$env.PACK_MANAGER != \$cmd) or (which \$cmd | is-empty) {
    return
  }
  if ('PACK_OP' in \$env) and (\$env.PACK_OP in ['add', 'rem']) and (\$env.PACKED? | default false) {
    return
  }
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input \$"? use (\$cmd) \\\\(system\\\\) [y, [n]]: "
  }
  if \$yn == 'n' {
    return
  }
  let cmd = if (which sudo | is-not-empty) { \$"sudo (\$cmd)" } else { \$cmd }
  packChocoOp \$cmd
}


def --env packScoopOp [cmd] {
  let filterArgs = \$env.PACK_LIST_NAMES | split words | each { |t| ['|', 'find', '--ignore-case', \$t] } | flatten
  if (\$filterArgs | is-not-empty) {
    opPrintMaybeRunCmd \$cmd list '|' complete '|' get stdout '|' str trim --right ...\$filterArgs
  } else {
    opPrintMaybeRunCmd \$cmd list
  }
}


def --env packScoop [] {
  let cmd = 'scoop'
  if ('PACK_MANAGER' in \$env and \$env.PACK_MANAGER != \$cmd) or (which \$cmd | is-empty) {
    return
  }
  if ('PACK_OP' in \$env) and (\$env.PACK_OP in ['add', 'rem']) and (\$env.PACKED? | default false) {
    return
  }
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input \$"? use (\$cmd) \\\\(user\\\\) [y, [n]]: "
  }
  if \$yn == 'n' {
    return
  }
  if 'PACK_OP' in \$env and (\$env.PACK_OP == 'add' or \$env.PACK_OP == 'find' or \$env.PACK_OP == 'out' or \$env.PACK_OP == 'sync') {
    opPrintMaybeRunCmd \$cmd update '|' complete '|' ignore
  }
  packScoopOp \$cmd
}


def --env packWingetOp [cmd] {
  let filterArgs = \$env.PACK_LIST_NAMES | split words | each { |t| ['|', 'find', '--ignore-case', \$t] } | flatten
  if (\$filterArgs | is-not-empty) {
    opPrintMaybeRunCmd \$cmd list ...\$filterArgs
  } else {
    opPrintMaybeRunCmd \$cmd list
  }
}


def --env packWinget [] {
  let cmd = 'winget'
  if ('PACK_MANAGER' in \$env and \$env.PACK_MANAGER != \$cmd) or (which \$cmd | is-empty) {
    return
  }
  if \$env.PACK_OP == 'tidy' {
    return
  }
  if ('PACK_OP' in \$env) and (\$env.PACK_OP in ['add', 'rem']) and (\$env.PACKED? | default false) {
    return
  }
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input \$"? use (\$cmd) \\\\(system/user\\\\) [y, [n]]: "
  }
  if \$yn == 'n' {
    return
  }
  packWingetOp \$cmd
}


\$env.PACK_LIST_NAMES = r#''#

packCargo
packChoco
packScoop
packWinget
\`
`;

