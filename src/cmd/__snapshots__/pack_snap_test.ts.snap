snapshot[`nu / arch / add (nushell) 1`] = `
\`\$env.REQ_URL_CFG = r#'http://x/cfg'#

\$env.REQ_URL_SH = r#'http://x/sh/nu/pack/add/nushell?sysOsPlat=linux&sysOs=arch'#

def opPrint --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  \$"(\$args | str join ' ')" | print
}

def opPrintErr --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print --stderr
    return
  }

  \$"(ansi red)(\$args | str join ' ')(ansi reset)" | print --stderr
}

def opPrintSucc --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi green)(\$args | str join ' ')(ansi reset)" | print
}

def opPrintWarn --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi yellow)(\$args | str join ' ')(ansi reset)" | print
}

def opPrintInfo --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi blue)(\$args | str join ' ')(ansi reset)" | print
}

def opPrintCmd --wrapped [...args] {
  if 'SUCCINCT' in \$env {
    return
  }
  if 'GRAYSCALE' in \$env {
    \$"(\$args | str join ' ')" | print
    return
  }

  \$"(ansi magenta)(\$args | first)(ansi reset)" | print --no-newline
  if (\$args | length) > 1 {
    \$" (ansi cyan)(\$args | skip 1 | str join ' ')(ansi reset)" | print
  }
}

def opRunCmd --wrapped [...args] {
  nu --no-config-file -c \$"(\$args | str join ' ')"
}

def opPrintRunCmd --wrapped [...args] {
  opPrintCmd ...\$args
  opRunCmd ...\$args
}

def opPrintMaybeRunCmd --wrapped [...args] {
  opPrintCmd ...\$args
  if 'NOOP' not-in \$env {
    opRunCmd ...\$args
  }
}


\$env.SH_VERS_MAJOR = 0

\$env.SH_VERS_MINOR = 111

do {
  let major = \$env.SH_VERS_MAJOR | into int
  let minor = \$env.SH_VERS_MINOR | into int

  if ((version | get major) < \$major) or ((version | get minor) < \$minor) {
    opPrintErr \$"nu must be >= '(\$major).(\$minor)' .. found '(version | get version)' .. aborting"
    exit 1
  }
}


\$env.REQ_ORIG = r#'http://x'#

\$env.SYS_OS = r#'arch'#

\$env.SYS_OS_PLAT = r#'linux'#

\$env.REQ_PATH = r#'/sh/nu/pack/add/nushell'#

\$env.REQ_SRCH = r#'?sysOsPlat=linux&sysOs=arch'#

\$env.PACK_ADD_NAMES = r#'nushell'#

\$env.PACK_OP = r#'add'#

def --env packCargoOp [cmd] {
  opPrintMaybeRunCmd \$cmd binstall --locked \$env.PACK_ADD_NAMES
  \$env.PACKED = true
}


def --env packCargo [] {
  let cmd = 'cargo'
  if ('PACK_MANAGER' in \$env and \$env.PACK_MANAGER != \$cmd) or (which \$cmd | is-empty) {
    return
  }
  if ('PACK_OP' in \$env) and (\$env.PACK_OP in ['add', 'rem']) and (\$env.PACKED? | default false) {
    return
  }
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input \$"? use (\$cmd) \\\\(user\\\\) [y, [n]]: "
  }
  if \$yn == 'n' {
    return
  }
  packCargoOp \$cmd
}


def --env packPacmanOp [cmd] {
  opPrintMaybeRunCmd \$cmd --sync --needed \$env.PACK_ADD_NAMES
  \$env.PACKED = true
}


def --env packPacman [] {
  let cmd = 'pacman'
  if 'PACK_MANAGER' not-in \$env and ((which yay | is-not-empty) or (which paru | is-not-empty)) {
    return
  }
  if ('PACK_MANAGER' in \$env and \$env.PACK_MANAGER != \$cmd) or (which \$cmd | is-empty) {
    return
  }
  if ('PACK_OP' in \$env) and (\$env.PACK_OP in ['add', 'rem']) and (\$env.PACKED? | default false) {
    return
  }
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input \$"? use (\$cmd) \\\\(system\\\\) [y, [n]]: "
  }
  if \$yn == 'n' {
    return
  }
  let cmd = if (which sudo | is-not-empty) { \$"sudo (\$cmd)" } else { \$cmd }
  if 'PACK_OP' in \$env and (\$env.PACK_OP == 'add' or \$env.PACK_OP == 'find' or \$env.PACK_OP == 'out' or \$env.PACK_OP == 'sync') {
    opPrintMaybeRunCmd \$cmd --sync --refresh '|' complete '|' ignore
  }
  packPacmanOp \$cmd
}




def --env packParu [] {
  let cmd = 'paru'
  if ('PACK_MANAGER' in \$env and \$env.PACK_MANAGER != \$cmd) or (which \$cmd | is-empty) {
    return
  }
  if ('PACK_OP' in \$env) and (\$env.PACK_OP in ['add', 'rem']) and (\$env.PACKED? | default false) {
    return
  }
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input \$"? use (\$cmd) \\\\(system\\\\) [y, [n]]: "
  }
  if \$yn == 'n' {
    return
  }
  if 'PACK_OP' in \$env and (\$env.PACK_OP == 'add' or \$env.PACK_OP == 'find' or \$env.PACK_OP == 'out' or \$env.PACK_OP == 'sync') {
    opPrintMaybeRunCmd \$cmd --sync --refresh '|' complete '|' ignore
  }
  packPacmanOp \$cmd
}




def --env packYay [] {
  let cmd = 'yay'
  if 'PACK_MANAGER' not-in \$env and (which paru | is-not-empty) {
    return
  }
  if ('PACK_MANAGER' in \$env and \$env.PACK_MANAGER != \$cmd) or (which \$cmd | is-empty) {
    return
  }
  if ('PACK_OP' in \$env) and (\$env.PACK_OP in ['add', 'rem']) and (\$env.PACKED? | default false) {
    return
  }
  mut yn = ''
  if 'YES' in \$env {
    \$yn = 'y'
  } else {
    \$yn = input \$"? use (\$cmd) \\\\(system\\\\) [y, [n]]: "
  }
  if \$yn == 'n' {
    return
  }
  if 'PACK_OP' in \$env and (\$env.PACK_OP == 'add' or \$env.PACK_OP == 'find' or \$env.PACK_OP == 'out' or \$env.PACK_OP == 'sync') {
    opPrintMaybeRunCmd \$cmd --sync --refresh '|' complete '|' ignore
  }
  packPacmanOp \$cmd
}


do --env {
mut yn = ''
if 'YES' in \$env {
  \$yn = 'y'
} else {
  \$yn = input r#'? use pack (user) [y, [n]]: '#
}
if \$yn != 'n' {
opPrint r#'shell-nushell'#
opPrint r#'  nu'#
\$env.PACK_MANAGER = r#'cargo'#
\$env.PACK_ADD_NAMES = r#'nu'#
packCargo
hide-env PACK_MANAGER
\$env.PACKED = true
} else {
\$yn = ''
if 'YES' in \$env {
  \$yn = 'y'
} else {
  \$yn = input r#'? use pack (system) [y, [n]]: '#
}
if \$yn != 'n' {
opPrint r#'shell-nushell'#
opPrint r#'  nushell'#
\$env.PACK_MANAGER = r#'pacman'#
\$env.PACK_ADD_NAMES = r#'nushell'#
packPacman
hide-env PACK_MANAGER
\$env.PACKED = true
}
}
}

\$env.PACK_ADD_NAMES = r#'nushell'#

packCargo
packPacman
packParu
packYay
\`
`;

