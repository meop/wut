  if not (packPrompt \$"use (\$cmd) \\\\(user\\\\)") { return }

  match \$env.PACK_OP {
    add => {
      packOp [\$cmd refresh]
      packOpAdd { |n| packSearch [\$cmd search] \$n } [\$cmd install]
    }
    find => {
      packOp [\$cmd refresh]
      packOpFind [\$cmd search]
    }
    list => {
